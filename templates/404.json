        "remove_horizontal_spacing": true,
        "liquid": "{% comment %}UGC Video Carousel DE{% endcomment %}\n<div class=\"sv-ugc-section\">\n  <h2 class=\"sv-ugc-title\">Kein Photoshop. Keine Filter.</h2>\n  <p class=\"sv-ugc-sub\">Nur SkinVeil™, zehn Minuten später.</p>\n  <div class=\"sv-ugc-scroll\" id=\"svUgcScroll\">\n    <div class=\"sv-ugc-track\" id=\"svUgcTrack\">\n      <div class=\"sv-ugc-card\">\n        <video src=\"https://cdn.shopify.com/videos/c/o/v/a72001712ee7406a87f2942cdb5702d9.mp4\" autoplay muted loop playsinline preload=\"metadata\"></video>\n      </div>\n      <div class=\"sv-ugc-card\">\n        <video src=\"https://cdn.shopify.com/videos/c/o/v/fc5bed58169b40c381c2f75203fc5956.mp4\" autoplay muted loop playsinline preload=\"metadata\"></video>\n      </div>\n      <div class=\"sv-ugc-card\">\n        <video src=\"https://cdn.shopify.com/videos/c/o/v/8f76cfbf5796444ba3cf9b51631ab66b.mp4\" autoplay muted loop playsinline preload=\"metadata\"></video>\n      </div>\n      <div class=\"sv-ugc-card\">\n        <video src=\"https://cdn.shopify.com/videos/c/o/v/3fadc61f2c0244578d6fb273ce8ef32c.mp4\" autoplay muted loop playsinline preload=\"metadata\"></video>\n      </div>\n    </div>\n  </div>\n  <div class=\"sv-ugc-dots\" id=\"svUgcDots\">\n    <span class=\"sv-dot active\" data-idx=\"0\"></span>\n    <span class=\"sv-dot\" data-idx=\"1\"></span>\n    <span class=\"sv-dot\" data-idx=\"2\"></span>\n    <span class=\"sv-dot\" data-idx=\"3\"></span>\n  </div>\n</div>\n<style>\n.sv-ugc-section{padding:32px 0 24px;background:#f5ede6;text-align:center;overflow:hidden}\n.sv-ugc-title{font-family:Georgia,serif;font-size:26px;font-style:italic;color:#1a1a2e;margin:0 0 6px;padding:0 16px;line-height:1.3}\n.sv-ugc-sub{font-size:14px;color:#888;margin:0 0 20px;padding:0 16px}\n.sv-ugc-scroll{width:100%;overflow:hidden;position:relative}\n.sv-ugc-track{display:flex;transition:transform 0.4s cubic-bezier(0.4,0,0.2,1);will-change:transform;gap:12px;padding:0}\n.sv-ugc-card{flex:0 0 78vw;max-width:300px;border-radius:16px;overflow:hidden;background:#000;aspect-ratio:9/16;position:relative;box-shadow:0 8px 24px rgba(0,0,0,0.14)}\n.sv-ugc-card video{width:100%;height:100%;object-fit:cover;display:block}\n.sv-ugc-dots{display:flex;justify-content:center;gap:8px;margin-top:18px}\n.sv-dot{width:8px;height:8px;border-radius:50%;background:#d4c4b8;cursor:pointer;transition:background 0.3s,transform 0.2s}\n.sv-dot.active{background:#c9a84c;transform:scale(1.3)}\n@media(min-width:768px){.sv-ugc-card{flex:0 0 calc(25% - 12px);max-width:280px}.sv-ugc-title{font-size:32px}}\n</style>\n<script>\n(function(){\n  var track=document.getElementById('svUgcTrack');\n  var scroll=document.getElementById('svUgcScroll');\n  var dots=document.querySelectorAll('.sv-dot');\n  var cards=document.querySelectorAll('.sv-ugc-card');\n  var total=cards.length;\n  var current=0;\n  var startX=0;\n  var isDragging=false;\n  var autoTimer;\n  function getCardWidth(){return cards[0].offsetWidth+12}\n  function getCenterOffset(){return(scroll.offsetWidth-cards[0].offsetWidth)/2}\n  function goTo(idx){\n    current=((idx%total)+total)%total;\n    var offset=current*getCardWidth()-getCenterOffset();\n    track.style.transform='translateX('+(-Math.max(0,offset))+'px)';\n    dots.forEach(function(d,i){d.classList.toggle('active',i===current)});\n  }\n  function next(){goTo(current+1)}\n  function startAuto(){autoTimer=setInterval(next,3500)}\n  function stopAuto(){clearInterval(autoTimer)}\n  dots.forEach(function(dot){\n    dot.addEventListener('click',function(){\n      stopAuto();goTo(parseInt(dot.dataset.idx));startAuto();\n    });\n  });\n  track.addEventListener('touchstart',function(e){startX=e.touches[0].clientX;isDragging=true;stopAuto()},{passive:true});\n  track.addEventListener('touchend',function(e){\n    if(!isDragging)return;\n    var diff=startX-e.changedTouches[0].clientX;\n    if(Math.abs(diff)>40){diff>0?next():goTo(current-1)}\n    isDragging=false;startAuto();\n  },{passive:true});\n  function init(){goTo(0);startAuto()}\n  if(document.readyState==='complete'){init()}else{window.addEventListener('load',init)}\n})();\n</script>",
