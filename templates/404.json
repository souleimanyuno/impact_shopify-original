    "custom_liquid_GeD8ep": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "{% comment %}UGC Photo Carousel DE{% endcomment %}\n\n<div class=\"ugc-carousel-wrapper\"> <div class=\"ugc-track\" id=\"ugcTrack\">\n<div class=\"ugc-card\">\n  <div class=\"ugc-img-wrap\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/IMG_6919_430x.jpg?v=1780978075\" alt=\"Emma Bewertung\" loading=\"lazy\">\n  </div>\n  <div class=\"ugc-review\">\n    <div class=\"ugc-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;</div>\n    <p class=\"ugc-text\">\"Ich hatte jahrelang dunkle Flecken auf den Beinen und habe sie immer versteckt. SkinVeil™ vor einem Grillabend aufgetragen und meine Schwester fragte, ob ich eine Laserbehandlung hatte. Hatte ich nicht, es ist einfach das hier.\"</p>\n    <div class=\"ugc-author\">\n      <span class=\"ugc-name\">Emma R.</span>\n      <span class=\"ugc-tag\">Verifizierter Kauf &middot; Berlin</span>\n    </div>\n  </div>\n</div>\n\n<div class=\"ugc-card\">\n  <div class=\"ugc-img-wrap\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/e1780d28-86f3-4820-833d-ffcd64e441ed_430x.jpg?v=1780978073\" alt=\"Sophie Bewertung\" loading=\"lazy\">\n  </div>\n  <div class=\"ugc-review\">\n    <div class=\"ugc-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;</div>\n    <p class=\"ugc-text\">\"Besenreiser hinter meinen Knien haben mich 4 Sommer lang davon abgehalten, Kleider zu tragen. Letztes Wochenende trug ich ein Midi-Kleid zur Hochzeit meiner Freundin. Niemand hat es bemerkt, nach der ersten Stunde auch ich nicht mehr.\"</p>\n    <div class=\"ugc-author\">\n      <span class=\"ugc-name\">Sophie M.</span>\n      <span class=\"ugc-tag\">Verifizierter Kauf &middot; München</span>\n    </div>\n  </div>\n</div>\n\n<div class=\"ugc-card\">\n  <div class=\"ugc-img-wrap\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/IMG_6920_430x.jpg?v=1780978074\" alt=\"Claire Bewertung\" loading=\"lazy\">\n  </div>\n  <div class=\"ugc-review\">\n    <div class=\"ugc-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;</div>\n    <p class=\"ugc-text\">\"Ich habe ein Tattoo an der Wade, das ich bereue. Zwei Schichten SkinVeil™ vor einem Vorstellungsgespräch aufgetragen, komplett unsichtbar. Zum ersten Mal seit 3 Jahren einen Rock getragen.\"</p>\n    <div class=\"ugc-author\">\n      <span class=\"ugc-name\">Claire T.</span>\n      <span class=\"ugc-tag\">Verifizierter Kauf &middot; Hamburg</span>\n    </div>\n  </div>\n</div>\n\n<div class=\"ugc-card\">\n  <div class=\"ugc-img-wrap\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/12712c8e3ad23d53bf99aa2dc28d5736_430x.jpg?v=1780978075\" alt=\"Natalie Bewertung\" loading=\"lazy\">\n  </div>\n  <div class=\"ugc-review\">\n    <div class=\"ugc-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;</div>\n    <p class=\"ugc-text\">\"Schwangerschaftsstreifen an meinen Oberschenkeln. Alles versucht, Bio-Oil monatelang, nichts. SkinVeil™ hat sie in 10 Minuten abgedeckt. Ich trug Shorts beim Schulabholen. Das erste Mal seit 2021.\"</p>\n    <div class=\"ugc-author\">\n      <span class=\"ugc-name\">Natalie B.</span>\n      <span class=\"ugc-tag\">Verifizierter Kauf &middot; Köln</span>\n    </div>\n  </div>\n</div>\n\n<div class=\"ugc-card\">\n  <div class=\"ugc-img-wrap\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/IMG_6922_430x.jpg?v=1780978074\" alt=\"Jessica Bewertung\" loading=\"lazy\">\n  </div>\n  <div class=\"ugc-review\">\n    <div class=\"ugc-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;</div>\n    <p class=\"ugc-text\">\"Urlaub mit den Mädels auf Mallorca. SkinVeil™ jeden Morgen aufgetragen, geschwommen, geschwitzt, bis 4 Uhr morgens getanzt. Kein Abfärben auf meinem weißen Bikini. Kein Nachbessern. Einfach ich, endlich wohl in meiner Haut.\"</p>\n    <div class=\"ugc-author\">\n      <span class=\"ugc-name\">Jessica H.</span>\n      <span class=\"ugc-tag\">Verifizierter Kauf &middot; Frankfurt</span>\n    </div>\n  </div>\n</div>\n\n<div class=\"ugc-card\">\n  <div class=\"ugc-img-wrap\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/f359b380-a1ae-4144-a9c1-2f476328adb8_430x.jpg?v=1780978073\" alt=\"Rachel Bewertung\" loading=\"lazy\">\n  </div>\n  <div class=\"ugc-review\">\n    <div class=\"ugc-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;</div>\n    <p class=\"ugc-text\">\"Knienarbe nach einer OP vor zwei Jahren. Eine Anwendung, 10 Minuten. Ich trug zum ersten Mal seit der Operation ein Kleid zur Geburtstagsparty meiner Nichte.\"</p>\n    <div class=\"ugc-author\">\n      <span class=\"ugc-name\">Rachel W.</span>\n      <span class=\"ugc-tag\">Verifizierter Kauf &middot; Stuttgart</span>\n    </div>\n  </div>\n</div>\n\n<div class=\"ugc-card\">\n  <div class=\"ugc-img-wrap\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0992/0384/2370/files/2a440f9b-9ca6-4bf8-b43e-7173095450ae_430x.jpg?v=1780978073\" alt=\"Lauren Bewertung\" loading=\"lazy\">\n  </div>\n  <div class=\"ugc-review\">\n    <div class=\"ugc-stars\">&#9733;&#9733;&#9733;&#9733;&#9733;</div>\n    <p class=\"ugc-text\">\"Chirurgische Narbe am Knie nach einer Sportverletzung. Ich trug immer Leggings im Fitnessstudio. SkinVeil™ vor einem Yoga-Kurs aufgetragen, Shorts angezogen. Meine Trainerin fragte, welche Feuchtigkeitscreme ich benutze.\"</p>\n    <div class=\"ugc-author\">\n      <span class=\"ugc-name\">Lauren K.</span>\n      <span class=\"ugc-tag\">Verifizierter Kauf &middot; Düsseldorf</span>\n    </div>\n  </div>\n</div>\n</div>\n  <div class=\"ugc-dots\" id=\"ugcDots\"></div>\n</div>\n<style>\n.ugc-carousel-wrapper{width:100%;overflow:hidden;margin-top:28px;background:#f5ede6}\n.ugc-track{display:flex;transition:transform 0.45s cubic-bezier(0.25,0.46,0.45,0.94);will-change:transform;cursor:grab;align-items:stretch}\n.ugc-track:active{cursor:grabbing}\n.ugc-card{min-width:100%;width:100%;flex-shrink:0;display:flex;flex-direction:column;background:#fff}\n.ugc-img-wrap{width:100%;aspect-ratio:3/4;overflow:hidden;background:#e8ddd6;flex-shrink:0}\n.ugc-img-wrap img{width:100%;height:100%;object-fit:cover;object-position:center top;display:block}\n.ugc-review{padding:18px 20px 22px;background:#fff;border-top:2px solid #f5ede6;flex:1;display:flex;flex-direction:column;justify-content:space-between}\n.ugc-stars{color:#f5a623;font-size:18px;margin-bottom:10px;letter-spacing:3px}\n.ugc-text{font-size:14px;line-height:1.65;color:#2a2a2a;margin:0 0 14px 0;font-style:italic;flex:1}\n.ugc-author{display:flex;flex-direction:column;gap:3px;border-top:1px solid #f0e8e0;padding-top:12px}\n.ugc-name{font-size:14px;font-weight:700;color:#1a1a2e}\n.ugc-tag{font-size:11px;color:#aaa;text-transform:uppercase;letter-spacing:0.5px}\n.ugc-dots{display:flex;justify-content:center;gap:7px;padding:16px 0 20px;background:#f5ede6}\n.ugc-dot{width:7px;height:7px;border-radius:50%;background:#c9b8ac;transition:background 0.3s,transform 0.3s;cursor:pointer}\n.ugc-dot.active{background:#1a1a2e;transform:scale(1.35)}\n@media(min-width:768px){.ugc-card{min-width:50%;width:50%}}\n</style>\n<script>\n(function(){\n  var track=document.getElementById('ugcTrack');\n  var dotsContainer=document.getElementById('ugcDots');\n  var cards=track.querySelectorAll('.ugc-card');\n  var total=cards.length;\n  var current=0;\n  var startX=0;\n  var isDragging=false;\n  var autoTimer;\n  function cardsPerView(){return window.innerWidth>=768?2:1}\n  function maxIndex(){return total-cardsPerView()}\n  function buildDots(){\n    dotsContainer.innerHTML='';\n    var count=maxIndex()+1;\n    for(var i=0;i<count;i++){\n      var dot=document.createElement('div');\n      dot.className='ugc-dot'+(i===0?' active':'');\n      dot.setAttribute('data-i',i);\n      dot.addEventListener('click',function(){goTo(parseInt(this.getAttribute('data-i')))});\n      dotsContainer.appendChild(dot);\n    }\n  }\n  function updateDots(){\n    dotsContainer.querySelectorAll('.ugc-dot').forEach(function(d,i){d.classList.toggle('active',i===current)});\n  }\n  function goTo(index){\n    var max=maxIndex();\n    current=((index%(max+1))+(max+1))%(max+1);\n    var pct=(100/cardsPerView())*current;\n    track.style.transform='translateX(-'+pct+'%)';\n    updateDots();\n  }\n  function next(){goTo(current+1)}\n  track.addEventListener('touchstart',function(e){startX=e.touches[0].clientX;clearInterval(autoTimer)},{passive:true});\n  track.addEventListener('touchend',function(e){\n    var diff=startX-e.changedTouches[0].clientX;\n    if(Math.abs(diff)>50){diff>0?next():goTo(current-1)}\n    startAuto();\n  },{passive:true});\n  track.addEventListener('mousedown',function(e){isDragging=true;startX=e.clientX;clearInterval(autoTimer)});\n  window.addEventListener('mouseup',function(e){\n    if(!isDragging)return;\n    isDragging=false;\n    var diff=startX-e.clientX;\n    if(Math.abs(diff)>50){diff>0?next():goTo(current-1)}\n    startAuto();\n  });\n  function startAuto(){clearInterval(autoTimer);autoTimer=setInterval(next,4000)}\n  window.addEventListener('resize',function(){buildDots();goTo(current)});\n  buildDots();goTo(0);startAuto();\n})();\n</script>",
