ogo {\n  height: 24px;\n  margin-top: -2px;\n}\n.video-proof-section {\n  text-align: center;\n  padding: 3rem 1rem;\n  background-color: #fdf8f4;\n}\n.video-proof-subtitle {\n  font-size: 0.95rem;\n  color: #888;\n  text-transform: uppercase;\n  letter-spacing: 0.08em;\n}\n.video-proof-wrapper {\n  max-width: 480px;\n  margin: 0 auto;\n  border-radius: 16px;\n  overflow: hidden;\nrgba(0,0,0,0.10);\n  background: #000;\n  aspect-ratio: 9/16;\n  position: relative;\n}\n.video-proof-player {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  display: block;\n}\n.video-proof-badge {\n  margin-top: 1.4rem;\n  margin-bottom: -10.4rem;\n  display: inline-block;\n  background-color: #C4614A;\n  color: #fff;\n  font-size: 0.85rem;\n  font-weight: 600;\n  padding: 0.25rem 1.2rem;\n  border-radius: 999px;\n  letter-spacing: 0.04em;\n}\n</style>",
