    "faq_aX8Tqy": {
      "type": "faq",
      "blocks": {
        "item_AxYrhi": {
          "type": "item",
          "settings": {
            "title": "Do they fit true to size?",
            "content": "<p>Yes, our boots fit true to US sizing standards. Choose your regular size. If you're between sizes, size up for extra comfort.</p>"
          }
        },
        "item_YVPrFj": {
          "type": "item",
          "settings": {
            "title": "How warm are they?",
            "content": "<p>The boots feature thick winter insulation that keeps feet warm down to -20°F. Engineered for harsh North American winters.</p>"
          }
        },
        "item_cFtpRw": {
          "type": "item",
          "settings": {
            "title": "Are they bulky or heavy?",
            "content": "<p>They're 45% lighter than traditional winter boots while providing the same warmth and protection. You won't feel weighed down.</p>"
          }
        },
        "item_eT3eQK": {
          "type": "item",
          "settings": {
            "title": "Can I use custom insoles?",
            "content": "<p>Yes, the boots work well with custom insoles for extra support and comfort.</p>"
          }
        },
        "item_K9DezK": {
          "type": "item",
          "settings": {
            "title": "How do I clean them?",
            "content": "<p>Wipe with a damp cloth. For tougher dirt, use mild soap and water. They dry quickly.</p>"
          }
        },
        "item_A6K9UF": {
          "type": "item",
          "settings": {
            "title": "Will they last more than one winter?",
            "content": "<p>Yes. Built with durable materials designed for multiple seasons. Many customers are on their 3rd+ winter with the same pair.</p>"
          }
        },
        "item_HXkUiJ": {
          "type": "item",
          "settings": {
            "title": "Can I wear them in the city or just for outdoor activities?",
            "content": "<p>Both. They work for snow shoveling, dog walks, commuting, and everyday winter wear. Clean design that doesn't look overly \"outdoorsy.\"</p>"
          }
        },
        "item_N4Bmqr": {
          "type": "item",
          "settings": {
            "title": "Do they work for wide feet?",
            "content": "<p>Yes. The wide toe box eliminates cramping and works well for wider feet or sensitive toes.</p>"
          }
        },
        "item_tAYcr8": {
          "type": "item",
          "settings": {
            "title": "Can I return them after wearing them outside?",
            "content": "<p>Yes. 30-day guarantee even if you've worn them. If they don't work for you, full refund.</p>"
          }
        }
      },
