    "custom_liquid_rQRi84": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": true,
        "remove_horizontal_spacing": true,
        "liquid": "<div class=\"why-fail-section\">\n\n  <div class=\"why-fail-header\">\n    <h2 class=\"why-fail-title\">You Didn't Lose Your Shape.<br>Your Bra Just Never Kept Up.</h2>\n    <p class=\"why-fail-sub\">Every bra in your drawer was built for a body that no longer needs what they offer. Here's why each one keeps letting you down.</p>\n  </div>\n\n  <div class=\"why-fail-card\">\n    <div class=\"why-fail-card-title\">\n      <span class=\"why-x\">✕</span>\n      <strong>Underwire bras</strong>\n    </div>\n    <p class=\"why-fail-card-body\">Digs into your ribs by noon. Puts all the pressure on two thin straps — so your shoulders carry the weight all day and your neck pays for it by 4pm.</p>\n  </div>\n\n  <div class=\"why-fail-card\">\n    <div class=\"why-fail-card-title\">\n      <span class=\"why-x\">✕</span>\n      <strong>Sports bras</strong>\n    </div>\n    <p class=\"why-fail-card-body\">Compresses instead of supports. Uniboob, no lift, no separation. And around hour six, that band that felt fine in the morning starts to feel like it's slowly tightening around you.</p>\n  </div>\n\n  <div class=\"why-fail-card\">\n    <div class=\"why-fail-card-title\">\n      <span class=\"why-x\">✕</span>\n      <strong>Bralettes</strong>\n    </div>\n    <p class=\"why-fail-card-body\">No structure at all. Fine for a small bust, useless for anything heavy. All the weight ends up on your shoulders — which is exactly where it shouldn't be.</p>\n  </div>\n\n  <div class=\"why-fail-card\">\n    <div class=\"why-fail-card-title\">\n      <span class=\"why-x\">✕</span>\n      <strong>S / M / L wireless bras</strong>\n    </div>\n    <p class=\"why-fail-card-body\">Sized for the model, not your ribcage. Too much stretch, too little structure. You spend the day constantly adjusting yourself back into the cups.</p>\n  </div>\n\n  <div class=\"why-fail-card why-fail-card--solution\">\n    <div class=\"why-fail-card-title\">\n      <span class=\"why-check\">✓</span>\n      <strong>ELORYA CloudCradle™</strong>\n    </div>\n    <p class=\"why-fail-card-body\">No wire. No compression. The CradleBand™ carries the weight from your ribcage — so your shoulders rest, your neck rests, and you forget you're wearing it by noon.</p>\n  </div>\n\n</div>\n\n<style>\n.why-fail-section {\n  background: #f9f5f2;\n  padding: 40px 20px;\n  max-width: 680px;\n  margin: 0 auto;\n}\n\n.why-fail-header {\n  text-align: center;\n  margin-bottom: 28px;\n}\n\n.why-fail-title {\n  font-size: clamp(22px, 5vw, 30px);\n  font-weight: 800;\n  color: #1a1a1a;\n  line-height: 1.25;\n  margin-bottom: 14px;\n}\n\n.why-fail-sub {\n  font-size: 15px;\n  color: #777;\n  line-height: 1.6;\n  max-width: 520px;\n  margin: 0 auto;\n}\n\n.why-fail-card {\n  background: #ffffff;\n  border-radius: 14px;\n  padding: 20px 20px;\n  margin-bottom: 12px;\n  box-shadow: 0 1px 4px rgba(0,0,0,0.06);\n}\n\n.why-fail-card--solution {\n  background: #fdf6f3;\n  border: 2px solid #C4614A;\n}\n\n.why-fail-card-title {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  margin-bottom: 10px;\n}\n\n.why-fail-card-title strong {\n  font-size: 17px;\n  color: #1a1a1a;\n}\n\n.why-x {\n  color: #C4614A;\n  font-size: 18px;\n  font-weight: 700;\n  line-height: 1;\n  flex-shrink: 0;\n}\n\n.why-check {\n  color: #2e7d32;\n  font-size: 20px;\n  font-weight: 700;\n  line-height: 1;\n  flex-shrink: 0;\n}\n\n.why-fail-card-body {\n  font-size: 14px;\n  color: #555;\n  line-height: 1.65;\n  margin: 0;\n}\n\n@media (max-width: 480px) {\n  .why-fail-section { padding: 32px 16px; }\n  .why-fail-card { padding: 16px; }\n}\n</style>",
