se\">✕</button>\n    </div>\n\n    <div class=\"cc-body\" id=\"ccBody\"></div>\n  </div>\n</div>\n\n<style>\n.cc-trigger-wrap { margin: 16px 0; }\n.cc-trigger {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  background: #fff;\n  border: 1px solid #e8ddd6;\n  border-radius: 12px;\n  padding: 14px 16px;\n  cursor: pointer;\n  transition: box-shadow 0.2s;\n}\n.cc-trigger:hover { box-shadow: 0 2px 12px rgba(0,0,0,0.08); }\n.cc-icon { font-size: 24px; }\n.cc-trigger-text {\n  display: flex;\n  flex-direction: column;\n  gap: 2px;\n}\n.cc-trigger-text em {\n  font-family: Georgia, serif;\n  font-size: 16px;\n  font-style: italic;\n  color: #1a1a1a;\n}\n.cc-trigger-text span {\n  font-size: 10px;\n  color: #aaa;\n  text-transform: uppercase;\n  letter-spacing: 0.8px;\n}\n.cc-arrow { margin-left: auto; font-size: 20px; color: #C4614A; }\n\n.cc-overlay {\n  display: none;\n  position: fixed;\n  inset: 0;\n  background: rgba(0,0,0,0.5);\n  z-index: 99999;\n  align-items: flex-end;\n  justify-content: center;\n}\n.cc-overlay.open { display: flex; }\n@media (min-width: 600px) { .cc-overlay { align-items: center; } }\n\n.cc-modal {\n  background: #fff;\n  width: 100%;\n  max-width: 520px;\n  max-height: 92vh;\n  border-radius: 20px 20px 0 0;\n  overflow: hidden;\n  display: flex;\n  flex-direction: column;\n}\n@media (min-width: 600px) {\n  .cc-modal { border-radius: 20px; max-height: 85vh; }\n}\n\n.cc-header {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding: 16px 16px 12px;\n  flex-shrink: 0;\n}\n.cc-back, .cc-close {\n  background: none;\n  border: none;\n  font-size: 18px;\n  cursor: pointer;\n  color: #666;\n  padding: 4px 8px;\n  border-radius: 6px;\n  flex-shrink: 0;\n}\n.cc-back:hover, .cc-close:hover { background: #f5f5f5; }\n.cc-progress-bar {\n  flex: 1;\n  height: 4px;\n  background: #efe8e2;\n  border-radius: 4px;\n  overflow: hidden;\n}\n.cc-progress-fill {\n  height: 100%;\n  background: #C4614A;\n  border-radius: 4px;\n  transition: width 0.4s ease;\n  width: 0%;\n}\n\n.cc-body {\n  overflow-y: auto;\n  padding: 0 20px 28px;\n  flex: 1;\n}\n\n.cc-step-label {\n  font-size: 11px;\n  font-weight: 700;\n  color: #C4614A;\n  text-transform: uppercase;\n  letter-spacing: 1px;\n  margin-bottom: 8px;\n  margin-top: 4px;\n}\n.cc-step-title {\n  font-family: Georgia, serif;\n  font-size: 24px;\n  font-style: italic;\n  color: #1a1a1a;\n  margin-bottom: 6px;\n  line-height: 1.3;\n}\n.cc-step-sub {\n  font-size: 13px;\n  color: #888;\n  margin-bottom: 20px;\n  line-height: 1.5;\n}\n\n.cc-ref-img {\n  width: 100%;\n  border-radius: 12px;\n  margin-bottom: 16px;\n  object-fit: cover;\n}\n\n.cc-options {\n  display: flex;\n  flex-direction: column;\n  gap: 10px;\n}\n.cc-option {\n  border: 2px solid #efe8e2;\n  border-radius: 12px;\n  padding: 14px 16px;\n  cursor: pointer;\n  transition: border-color 0.2s, background 0.2s;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n}\n.cc-option:hover { border-color: #C4614A; }\n.cc-option.selected { border-color: #C4614A; background: #fdf6f3; }\n.cc-option strong {\n  font-size: 15px;\n  color: #1a1a1a;\n}\n.cc-option span {\n  font-size: 12px;\n  color: #aaa;\n}\n.cc-option-check {\n  width: 20px;\n  height: 20px;\n  border-radius: 50%;\n  border: 2px solid #efe8e2;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 11px;\n  color: transparent;\n  flex-shrink: 0;\n}\n.cc-option.selected .cc-option-check {\n  background: #C4614A;\n  border-color: #C4614A;\n  color: #fff;\n}\n\n/* RESULT */\n.cc-result-header {\n  text-align: center;\n  padding: 8px 0 16px;\n}\n.cc-result-badge {\n  display: inline-block;\n  background: #C4614A;\n  color: #fff;\n  font-size: 11px;\n  font-weight: 700;\n  text-transform: uppercase;\n  letter-spacing: 0.8px;\n  padding: 4px 12px;\n  border-radius: 999px;\n  margin-bottom: 12px;\n}\n.cc-result-size {\n  font-family: Georgia, serif;\n  font-size: 52px;\n  font-style: italic;\n  color: #1a1a1a;\n  line-height: 1;\n  margin-bottom: 4px;\n}\n.cc-result-name {\n  font-size: 13px;\n  color: #888;\n  margin-bottom: 0;\n}\n.cc-size-card {\n  background: #fdf6f3;\n  border: 2px solid #C4614A;\n  border-radius: 14px;\n  padding: 16px;\n  margin-bottom: 14px;\n}\n.cc-size-row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  font-size: 13px;\n  color: #555;\n  padding: 6px 0;\n  border-bottom: 1px solid #efe8e2;\n}\n.cc-size-row:last-child { border-bottom: none; }\n.cc-size-row strong { color: #1a1a1a; }\n.cc-why-box {\n  background: #f9f5f3;\n  border-radius: 12px;\n  padding: 14px 16px;\n  margin-bottom: 16px;\n  font-size: 13px;\n  color: #5a4030;\n  line-height: 1.6;\n}\n.cc-why-box strong {\n  display: block;\n  font-size: 10px;\n  text-transform: uppercase;\n  letter-spacing: 0.8px;\n  color: #C4614A;\n  margin-bottom: 6px;\n}\n.cc-cta-btn {\n  width: 100%;\n  background: #C4614A;\n  color: #fff;\n  border: none;\n  border-radius: 12px;\n  padding: 16px;\n  font-size: 16px;\n  font-weight: 700;\n  cursor: pointer;\n  margin-bottom: 8px;\n  transition: opacity 0.2s;\n}\n.cc-cta-btn:hover { opacity: 0.88; }\n.cc-cta-sub {\n  text-align: center;\n  font-size: 12px;\n  color: #aaa;\n  margin-bottom: 16px;\n}\n.cc-trust-row {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 8px;\n  border-top: 1px solid #f0e8e0;\n  padding-top: 16px;\n}\n.cc-trust-item { text-align: center; }\n.cc-trust-item em {\n  display: block;\n  font-family: Georgia, serif;\n  font-size: 15px;\n  font-style: italic;\n  color: #C4614A;\n  margin-bottom: 2px;\n}\n.cc-trust-item span { font-size: 10px; color: #aaa; line-height: 1.3; }\n.cc-restart {\n  display: block;\n  text-align: center;\n  font-size: 13px;\n  color: #aaa;\n  cursor: pointer;\n  margin-top: 16px;\n  text-decoration: underline;\n}\n</style>\n\n<script>\n(function() {\n\n  const SIZE_MAP = {\n    // [band][cup] => size\n    '28-30': { 'A-B': 'S',   'C-D': 'S',   'DD-E': 'M',  'F-G-H': 'M'  },\n    '32-34': { 'A-B': 'S',   'C-D': 'M',   'DD-E': 'M',  'F-G-H': 'L'  },\n    '36-38': { 'A-B': 'M',   'C-D': 'L',   'DD-E': 'L',  'F-G-H': 'XL' },\n    '40-42': { 'A-B': 'L',   'C-D': 'XL',  'DD-E': 'XL', 'F-G-H': 'XXL'},\n    '44+':   { 'A-B': 'XL',  'C-D': 'XXL', 'DD-E': 'XXL','F-G-H': 'XXL'}\n  };\n\n  const SIZE_DETAILS = {\n    'S':   { label: 'Small',       band: '28–34\"',  cup: 'A to C',   fits: 'Petite to average frame, lighter bust' },\n    'M':   { label: 'Medium',      band: '32–36\"',  cup: 'B to DD',  fits: 'Average frame, medium bust' },\n    'L':   { label: 'Large',       band: '36–40\"',  cup: 'C to E',   fits: 'Fuller frame or generous bust' },\n    'XL':  { label: 'Extra Large', band: '38–42\"',  cup: 'D to G',   fits: 'Full figure, heavy bust' },\n    'XXL': { label: 'XX-Large',    band: '42–44+\"', cup: 'E to H+',  fits: 'Plus size, very heavy bust' }\n  };\n\n  const COLOR_REC = {\n    'S':   'Sand or Cloud',\n    'M':   'Sand or Midnight',\n    'L':   'Midnight or Sand',\n    'XL':  'Midnight or Sand',\n    'XXL': 'Midnight or Sand'\n  };\n\n  let band = null;\n  let cup  = null;\n  let step = 1;\n\n  const trigger    = document.getElementById('ccTrigger');\n  const overlay    = document.getElementById('ccOverlay');\n  const body       = document.getElementById('ccBody');\n  const fill       = document.getElementById('ccProgressFill');\n  const backBtn    = document.getElementById('ccBack');\n  const closeBtn   = document.getElementById('ccClose');\n\n  trigger.addEventListener('click', () => { step=1; band=null; cup=null; open(); });\n  closeBtn.addEventListener('click', close);\n  overlay.addEventListener('click', e => { if(e.target===overlay) close(); });\n  backBtn.addEventListener('click', () => { step = Math.max(1, step-1); render(); });\n\n  function open()  { overlay.classList.add('open'); render(); }\n  function close() { overlay.classList.remove('open'); }\n\n  function setProgress(s, total) {\n    fill.style.width = (s / total * 100) + '%';\n    backBtn.style.visibility = s > 1 ? 'visible' : 'hidden';\n  }\n\n  function render() {\n    if (step === 1) renderQ1();\n    else if (step === 2) renderQ2();\n    else renderResult();\n    body.scrollTop = 0;\n  }\n\n  function renderQ1() {\n    setProgress(1, 2);\n    const bands = [\n      { val: '28-30', label: '28 – 30\"', sub: '71 – 76 cm' },\n      { val: '32-34', label: '32 – 34\"', sub: '81 – 86 cm' },\n      { val: '36-38', label: '36 – 38\"', sub: '91 – 97 cm' },\n      { val: '40-42', label: '40 – 42\"', sub: '101 – 107 cm' },\n      { val: '44+',   label: '44\"+',     sub: '112 cm +' }\n    ];\n    body.innerHTML = `\n      <p class=\"cc-step-label\">QUESTION 1 OF 2</p>\n      <h2 class=\"cc-step-title\">What's your band size?</h2>\n      <p class=\"cc-step-sub\">Measure snugly around your ribcage, just below your bust. Don't hold your breath.</p>\n      <img\n        class=\"cc-ref-img\"\n        src=\" https://cdn.shopify.com/s/files/1/0795/2754/3033/files/ChatGPT_Image_10_juil._2026_23_56_18_430x.png?v=1783724274\"\n        alt=\"How to measure your band size\"\n      >\n      <div class=\"cc-options\">\n        ${bands.map(b => `\n          <div class=\"cc-option${band===b.val?' selected':''}\" data-val=\"${b.val}\">\n            <div>\n              <strong>${b.label}</strong>\n              <span style=\"margin-left:8px;\">${b.sub}</span>\n            </div>\n            <div class=\"cc-option-check\">✓</div>\n          </div>\n        `).join('')}\n      </div>`;\n    body.querySelectorAll('.cc-option').forEach(el => {\n      el.addEventListener('click', () => {\n        band = el.dataset.val;\n        step = 2; render();\n      });\n    });\n  }\n\n  function renderQ2() {\n    setProgress(2, 2);\n    const cups = [\n      { val: 'A-B',   label: 'A – B',   sub: 'Small to light bust'    },\n      { val: 'C-D',   label: 'C – D',   sub: 'Medium bust'            },\n      { val: 'DD-E',  label: 'DD – E',  sub: 'Full bust'              },\n      { val: 'F-G-H', label: 'F – H+',  sub: 'Heavy or very full bust'}\n    ];\n    body.innerHTML = `\n      <p class=\"cc-step-label\">QUESTION 2 OF 2</p>\n      <h2 class=\"cc-step-title\">How would you describe your bust volume?</h2>\n      <p class=\"cc-step-sub\">Choose the closest match — exact cup letter doesn't matter.</p>\n      <img\n        class=\"cc-ref-img\"\n        src=\"https://cdn.shopify.com/s/files/1/0795/2754/3033/files/ChatGPT_Image_10_juil._2026_23_57_15_430x.png?v=1783724275\"\n        alt=\"Bust volume guide\"\n      >\n      <div class=\"cc-options\">\n        ${cups.map(c => `\n          <div class=\"cc-option${cup===c.val?' selected':''}\" data-val=\"${c.val}\">\n            <div>\n              <strong>${c.label}</strong>\n              <span style=\"margin-left:8px;\">${c.sub}</span>\n            </div>\n            <div class=\"cc-option-check\">✓</div>\n          </div>\n        `).join('')}\n      </div>`;\n    body.querySelectorAll('.cc-option').forEach(el => {\n      el.addEventListener('click', () => {\n        cup = el.dataset.val;\n        step = 3; render();\n      });\n    });\n  }\n\n  function renderResult() {\n    setProgress(3, 2);\n    fill.style.width = '100%';\n    const size    = SIZE_MAP[band][cup];\n    const details = SIZE_DETAILS[size];\n    const color   = COLOR_REC[size];\n\n    body.innerHTML = `\n      <div class=\"cc-result-header\">\n        <div class=\"cc-result-badge\">YOUR SIZE</div>\n        <div class=\"cc-result-size\">${size}</div>\n        <p class=\"cc-result-name\">${details.label} · CloudCradle™</p>\n      </div>\n\n      <div class=\"cc-size-card\">\n        <div class=\"cc-size-row\">\n          <span>Band range</span>\n          <strong>${details.band}</strong>\n        </div>\n        <div class=\"cc-size-row\">\n          <span>Cup range</span>\n          <strong>${details.cup}</strong>\n        </div>\n        <div class=\"cc-size-row\">\n          <span>Best for</span>\n          <strong>${details.fits}</strong>\n        </div>\n        <div class=\"cc-size-row\">\n          <span>Recommended color</span>\n          <strong>${color}</strong>\n        </div>\n      </div>\n\n      <div class=\"cc-why-box\">\n        <strong>WHY THIS SIZE</strong>\n        The CradleBand™ is designed to carry weight from your ribcage — not your shoulders. \n        Getting the band right is what makes the difference. If you're between two sizes, go up.\n      </div>\n\n      <button class=\"cc-cta-btn\" id=\"ccAddBtn\">Shop my size — ${size}</button>\n      <p class=\"cc-cta-sub\">Free exchanges if it doesn't fit perfectly</p>\n\n      <div class=\"cc-trust-row\">\n        <div class=\"cc-trust-item\"><em>30 days</em><span>DayOne Guarantee</span></div>\n        <div class=\"cc-trust-item\"><em>Free</em><span>Exchanges on every order</span></div>\n        <div class=\"cc-trust-item\"><em>4.8★</em><span>3,200+ women</span></div>\n      </div>\n\n      <span class=\"cc-restart\" id=\"ccRestart\">↺ Retake the quiz</span>`;\n\n    document.getElementById('ccAddBtn').addEventListener('click', () => {\n      close();\n      const atcBtn = document.querySelector('[name=\"add\"], .product-form__submit, #AddToCart');\n      if (atcBtn) atcBtn.scrollIntoView({ behavior: 'smooth', block: 'center' });\n    });\n    document.getElementById('ccRestart').addEventListener('click', () => {\n      band = null; cup = null; step = 1; render();\n    });\n  }\n\n  render();\n})();\n</script>"
          }
        },
