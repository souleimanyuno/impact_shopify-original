        "testimonial_UGQYqW": {
          "type": "testimonial",
          "settings": {
            "round_avatar": true,
            "show_rating": true,
            "rating": 5,
            "author": "",
            "title": "01-25-2026 · Sarah K.",
            "content": "<p>Bought these after slipping on my driveway and nearly breaking my wrist. The grip is NO JOKE. Walked on pure ice yesterday and felt completely stable. First winter boots that actually deliver on the non-slip promise.</p>"
          }
        },
        "testimonial_FXDEwy": {
          "type": "testimonial",
          "settings": {
            "round_avatar": true,
            "show_rating": true,
            "rating": 5,
