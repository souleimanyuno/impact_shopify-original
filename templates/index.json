letter-spacing: 0.07em;\n  white-space: nowrap;\n  padding: 0 28px;\n}\n\n.ticker-item svg {\n  color: #C4614A;\n  flex-shrink: 0;\n}\n\n@keyframes ticker-scroll {\n  0%   { transform: translateX(0); }\n  100% { transform: translateX(-50%); }\n}\n\n@media (max-width: 480px) {\n  .ticker-item {\n    font-size: 10px;\n    padding: 0 20px;\n    gap: 5px;\n  }\n  .ticker-item svg {\n    width: 12px;\n    height: 12px;\n  }\n}\n</style>",
